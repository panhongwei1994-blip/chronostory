---
import BossTimerApp from "../components/BossTimerApp.vue";
import "../styles/maple.css";
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BOSS 刷新倒计时</title>
    <meta name="description" content="枫之谷 BOSS 刷新倒计时看守工具，支持游戏屏幕画面 AI 自动识别捕获、寒霜冰龙(10m)、黑金刚(30m)、鱼头(30m)，纯本地单人极速响应，亚服/美服当地凌晨01:00自动重置。" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- 引入 Tesseract.js 纯前端网页 OCR 识别引擎 -->
    <script src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>
  </head>
  <body>
    <main>
      <BossTimerApp client:load />
    </main>
  </body>
</html>
